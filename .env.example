# PRISMA Analyzer Configuration
# Copy this to .env and adjust as needed

# ===== OLLAMA CONFIGURATION =====
# For LOCAL Ollama (default):
#   OLLAMA_BASE_URL=http://localhost:11434
#   OLLAMA_MODEL=gemma4:31b-cloud
#   (No API key needed)
#
# For REMOTE/CLOUD Ollama:
#   OLLAMA_BASE_URL=https://your-ollama-cloud.example.com
#   OLLAMA_MODEL=gemma4:31b-cloud
#   OLLAMA_API_KEY=your_api_key_here

# Ollama Server Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud

# API Key (only needed for remote/authenticated Ollama)
# Leave empty for local Ollama
OLLAMA_API_KEY=

# Output Configuration  
OUTPUT_DIR=output/reports
LOG_DIR=output/logs

# LLM Parameters
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TOP_P=0.9

# PDF Processing
PDF_CHUNK_SIZE=1500
PDF_CHUNK_OVERLAP=200

# Logging
LOG_LEVEL=INFO
